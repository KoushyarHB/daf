  {
    "head": "Wie heißt ...? /viː haɪ̯st/",
    "gloss": ["What is ... called?"],
    "notes": [
      "• W-question pattern: Wie is position 1, the finite verb heißt is position 2."
    ],
    "examples": [
      {
        "german": "Wie heißt Ihr Land in Ihrer Sprache?",
        "english": "What is your country called in your language? [formal]"
      },
      {
        "german": "Wie heißt das auf Deutsch?",
        "english": "What is that called in German?"
      }
    ],
    "createdAt": "2026-05-15T19:19:00Z",
    "updatedAt": "2026-05-15T19:19:00Z",
    "lektion": 1,
    "level": "A1"
  },
