    "plural": "Länder",
    "gloss": ["Country; land."],
    "notes": [],
    "examples": [
      {
        "german": "Ihr Land heißt Iran.",
        "english": "Your country is called Iran. [formal]"
      },
      {
        "german": "Wie heißt Ihr Land?",
        "english": "What is your country called? [formal]"
      }
