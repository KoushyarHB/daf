        "german": "Ich lerne Ihre Sprache.",
        "english": "I am learning your language. [formal; accusative]"
      },
      {
        "german": "Ich spreche in Ihrer Sprache.",
        "english": "I speak in your language. [formal; dative]"
      }
    ],
    "createdAt": "2026-05-15T19:19:00Z",
    "updatedAt": "2026-05-15T19:19:00Z",
    "lektion": 1,
    "level": "A1"
  },
